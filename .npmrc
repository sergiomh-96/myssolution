shamefully-hoist=true
strict-peer-dependencies=false
public-hoist-patterns[]=*eslint*
public-hoist-patterns[]=*prettier*

# Exclude problematic packages that break the build
ignore-workspace-root-check=false

# Override pdfkit and fontkit to empty so they don't get installed
overrides:
  pdfkit: "virtual"
  fontkit: "virtual"
  "pdfkit@*": "virtual"
  "fontkit@*": "virtual"
